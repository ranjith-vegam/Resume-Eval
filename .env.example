PORT=8000

# MongoDB (see docker-compose.yml — `docker compose up -d` to start it)
MONGO_ROOT_USER=resume_eval
MONGO_ROOT_PASSWORD=changeme
MONGO_PORT=27019
MONGO_URI=mongodb://resume_eval:changeme@localhost:27019/?authSource=admin
MONGO_DB_NAME=resume_eval

# Dockerized app (docker compose up --build): host-side port the app is reachable on.
# The app container talks to Mongo over the internal docker network, not MONGO_URI above.
APP_PORT=8123
